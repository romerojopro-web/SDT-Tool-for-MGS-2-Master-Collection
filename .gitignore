# ── Game data: NEVER in the repo (copyrighted Konami files) ──────────────────
# Dumps, archives, banks, bundles, extracted audio — whatever the folder.
*.dat
*.sdx
*.sdt
*.wav
*.bundle
*.dar
*.qar
*.gcx
*.cnf
*.bak

# Game executables and any unprotected image of them — NEVER in the repo.
# The reverse-engineering notes in docs/ are interoperability research on your
# own legally-owned copy; the binary itself must not be committed.
*.exe
*.unpacked
*unpacked*.exe
tests/mgs2_substance_2003/
scripts/sdx_mgs2_MC/

# ── Build / packaging output ─────────────────────────────────────────────────
dist/

# ── Python noise ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/

